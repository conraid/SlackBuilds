From 32dbb393f075967ba349036dbac28a625de3f98f Mon Sep 17 00:00:00 2001
From: Bill Roberts <bill.roberts@arm.com>
Date: Tue, 20 Jan 2026 10:40:04 -0600
Subject: [PATCH] bug: fix const correctness
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

gcc 16, correctly, points out some const correctness bugs in the code:

../../src/rist-common.c: In function ‘parse_url_udp_options’:
../../src/rist-common.c:58:15: error: assignment discards ‘const’ qualifier from pointer target type [-Wdiscarded-qualifiers]
   58 |         query = strchr( url, '/' );

../src/udpsocket.c: In function ‘udpsocket_parse_url_parameters’:
../src/udpsocket.c:388:15: error: assignment discards ‘const’ qualifier from pointer target type [-Wdiscarded-qualifiers]
  388 |         query = strchr( url, '?' );

Both of these warnings are around the usage of
udpsocket_parse_url_parameters. The function takes a URL and parses it
into a list of type udpsocket_url_param. That function usese strtok to
parse the URL, which modifies the url string and thus cannot be const.
Additionally, it populates the list of type udpsocket_url_param with
pointers back into the url string itself. Becuase of this, callers
need a mutable url and those pointers within the list of
udpsocket_url_param to be valid. So have the two call sites create a
mutable copy of the URL to work on, and free the copy before they
return. This will provide a mutable url for strtok as well as provide
for stable pointers within the paramter list key values.

Signed-off-by: Bill Roberts <bill.roberts@arm.com>
---
 include/librist/udpsocket.h | 11 ++++++++++-
 src/rist-common.c           | 22 +++++++++++++++++-----
 src/udpsocket.c             |  2 +-
 3 files changed, 28 insertions(+), 7 deletions(-)

diff --git a/include/librist/udpsocket.h b/include/librist/udpsocket.h
index 717b301..8ff732c 100644
--- a/include/librist/udpsocket.h
+++ b/include/librist/udpsocket.h
@@ -137,7 +137,16 @@ RIST_API int udpsocket_recv(int sd, void *buf, size_t size);
 RIST_API int udpsocket_recvfrom(int sd, void *buf, size_t size, int flags, struct sockaddr *addr, socklen_t *addr_len);
 RIST_API int udpsocket_close(int sd);
 RIST_API int udpsocket_parse_url(char *url, char *address, int address_maxlen, uint16_t *port, int *local);
-RIST_API int udpsocket_parse_url_parameters(const char *url, udpsocket_url_param_t *params,
+/**
+ * @brief Parses a URL and updates the list of parameters.
+ *
+ * @param url: The url to parse, note that the url string is modified!
+ * @param params: The parameter list to populate.
+ * @param max_params: The length of the parameter list.
+ * @clean_url_len: The length of the resource path in the URL.
+ * @return the number of url parameters
+ */
+RIST_API int udpsocket_parse_url_parameters(char *url, udpsocket_url_param_t *params,
          int max_params, uint32_t *clean_url_len);
 
 
diff --git a/src/rist-common.c b/src/rist-common.c
index 2941c5f..ee2703a 100755
--- a/src/rist-common.c
+++ b/src/rist-common.c
@@ -55,10 +55,14 @@ int parse_url_udp_options(const char* url, struct rist_udp_config *output_udp_co
 	if (!url || !url[0] || !output_udp_config)
 		return -1;
 
-	query = strchr( url, '/' );
+	char *tmp_url = strdup( url );
+	if (!tmp_url)
+		return -1;
+
+	query = strchr( tmp_url, '/' );
 	if (query != NULL) {
-		prefix_len = (uint32_t)(query - url);
-		strncpy((void *)output_udp_config->prefix, url, prefix_len >= 16 ? 15 : prefix_len - 1);
+		prefix_len = (uint32_t)(query - tmp_url);
+		strncpy((void *)output_udp_config->prefix, tmp_url, prefix_len >= 16 ? 15 : prefix_len - 1);
 		output_udp_config->prefix[prefix_len] = '\0';
 		// Convert to lower
 		char *p =(char *)output_udp_config->prefix;
@@ -76,7 +80,7 @@ int parse_url_udp_options(const char* url, struct rist_udp_config *output_udp_co
 	}
 
 	// Parse URL parameters
-	num_params = udpsocket_parse_url_parameters( url, url_params,
+	num_params = udpsocket_parse_url_parameters( tmp_url, url_params,
 			sizeof(url_params) / sizeof(struct udpsocket_url_param), &clean_url_len );
 	if (num_params > 0) {
 		for (i = 0; i < num_params; ++i) {
@@ -116,6 +120,8 @@ int parse_url_udp_options(const char* url, struct rist_udp_config *output_udp_co
 	}
 	strncpy((void *)output_udp_config->address, url, clean_url_len >= RIST_MAX_STRING_LONG ? RIST_MAX_STRING_LONG-1 : clean_url_len - 1);
 
+	free( tmp_url );
+
 	if (ret != 0)
 		return num_params;
 	else
@@ -134,7 +140,11 @@ int parse_url_options(const char* url, struct rist_peer_config *output_peer_conf
 		return -1;
 
 	// Parse URL parameters
-	num_params = udpsocket_parse_url_parameters( url, url_params,
+	char *tmp_url = strdup( url );
+	if (!tmp_url)
+		return -1;
+
+	num_params = udpsocket_parse_url_parameters( tmp_url, url_params,
 			sizeof(url_params) / sizeof(struct udpsocket_url_param), &clean_url_len );
 	if (num_params > 0) {
 		for (i = 0; i < num_params; ++i) {
@@ -245,6 +255,8 @@ int parse_url_options(const char* url, struct rist_peer_config *output_peer_conf
 	}
 	strncpy((void *)output_peer_config->address, url, clean_url_len >= RIST_MAX_STRING_LONG ? RIST_MAX_STRING_LONG-1 : clean_url_len - 1);
 
+	free( tmp_url );
+
 	if (ret != 0)
 		return num_params;
 	else
diff --git a/src/udpsocket.c b/src/udpsocket.c
index 163ca54..80c0a40 100644
--- a/src/udpsocket.c
+++ b/src/udpsocket.c
@@ -378,7 +378,7 @@ int udpsocket_close(int sd)
 #endif
 }
 
-int udpsocket_parse_url_parameters(const char *url, udpsocket_url_param_t *params, int max_params,
+int udpsocket_parse_url_parameters(char *url, udpsocket_url_param_t *params, int max_params,
 	uint32_t *clean_url_len)
 {
 	char* query = NULL;
-- 
